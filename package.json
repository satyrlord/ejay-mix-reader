{
  "name": "ejay-mix-reader",
  "version": "1.27",
  "private": true,
  "type": "module",
  "description": "Extract and browse audio samples from eJay music software titles.",
  "scripts": {
    "serve": "vite",
    "build": "tsx scripts/build-index.ts && vite build",
    "preview": "vite preview",
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:coverage": "tsx scripts/test-coverage.ts",
    "test:ui": "playwright test --ui",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.browser.json && tsc -p tsconfig.config.json && tsc -p tsconfig.test.json",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "validate": "npm run typecheck && npm run test:unit:coverage && npm run lint:md"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/satyrlord/ejay-mix-reader.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "daisyui": "^5.5.19",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "markdownlint-cli2": "^0.22.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-istanbul": "^8.0.0",
    "vitest": "^4.1.4"
  }
}
