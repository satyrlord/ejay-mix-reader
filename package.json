{
  "name": "ejay-mix-reader",
  "version": "1.27.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "description": "Extract and browse audio samples from eJay music software titles.",
  "scripts": {
    "serve": "vite",
    "setup": "tsx scripts/build-library.ts",
    "build:web": "tsx scripts/build-index.ts && vite build",
    "build": "npm run build:web",
    "build:electron": "node ./node_modules/typescript/lib/tsc.js -p tsconfig.electron.json",
    "build:desktop": "npm run build:web && npm run build:electron",
    "electron": "electron ./dist-electron/electron/main.js",
    "electron:dev": "tsx scripts/run-electron-dev.ts",
    "dist:win": "npm run build:desktop && electron-builder --win nsis portable --x64 --publish never",
    "mix:extract-embedded": "tsx scripts/extract-embedded-mix-audio.ts",
    "mix:meta": "tsx scripts/extract-mix-metadata.ts",
    "mix:dump-cd": "tsx scripts/mix-format-cd-records.ts",
    "mix:diff-cd": "tsx scripts/mix-format-cd-diff.ts",
    "mix:audit-cd": "tsx scripts/mix-format-cd-audit.ts",
    "samples:missing": "tsx scripts/gen-missing-beats-report.ts",
    "samples:recover": "tsx scripts/recover-missing-samples.ts",
    "samples:update": "tsx scripts/recover-missing-samples.ts",
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:coverage": "tsx scripts/test-coverage.ts",
    "test:ui": "playwright test --ui",
    "typecheck": "node ./node_modules/typescript/lib/tsc.js -p tsconfig.json && node ./node_modules/typescript/lib/tsc.js -p tsconfig.browser.json && node ./node_modules/typescript/lib/tsc.js -p tsconfig.config.json && node ./node_modules/typescript/lib/tsc.js -p tsconfig.test.json && node ./node_modules/typescript/lib/tsc.js -p tsconfig.electron.json",
    "lint": "eslint .",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "validate": "npm run typecheck && npm run lint && npm run test:unit:coverage && npm run lint:md"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/satyrlord/ejay-mix-reader.git"
  },
  "build": {
    "appId": "com.ejay.mixreader",
    "productName": "MixJam",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "data/**",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": true,
      "icon": "images/app-icon.ico",
      "executableName": "MixJam",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "images/app-icon.ico",
      "uninstallerIcon": "images/app-icon.ico",
      "installerHeaderIcon": "images/app-icon.ico"
    },
    "portable": {
      "artifactName": "MixJam.exe"
    }
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "daisyui": "^5.5.19",
    "electron": "^41.5.0",
    "electron-builder": "^26.0.12",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "markdownlint-cli2": "^0.22.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vite-plugin-istanbul": "^8.0.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
