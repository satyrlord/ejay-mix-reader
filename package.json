{
  "name": "ejay-mix-reader",
  "version": "1.27",
  "private": true,
  "type": "module",
  "description": "Extract and browse audio samples from eJay music software titles.",
  "scripts": {
    "serve": "vite",
    "setup": "tsx scripts/build-library.ts",
    "build": "tsx scripts/build-index.ts && vite build",
    "preview": "vite preview",
    "mix:extract-embedded": "tsx scripts/extract-embedded-mix-audio.ts",
    "mix:meta": "tsx scripts/extract-mix-metadata.ts",
    "mix:dump-cd": "tsx scripts/mix-format-cd-records.ts",
    "mix:diff-cd": "tsx scripts/mix-format-cd-diff.ts",
    "mix:audit-cd": "tsx scripts/mix-format-cd-audit.ts",
    "samples:missing": "tsx scripts/gen-missing-beats-report.ts",
    "samples:recover": "tsx scripts/recover-missing-samples.ts",
    "samples:update": "tsx scripts/recover-missing-samples.ts",
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:coverage": "tsx scripts/test-coverage.ts",
    "test:ui": "playwright test --ui",
    "typecheck": "node ./node_modules/typescript/lib/tsc.js -p tsconfig.json && node ./node_modules/typescript/lib/tsc.js -p tsconfig.browser.json && node ./node_modules/typescript/lib/tsc.js -p tsconfig.config.json && node ./node_modules/typescript/lib/tsc.js -p tsconfig.test.json",
    "lint": "eslint .",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "validate": "npm run typecheck && npm run lint && npm run test:unit:coverage && npm run lint:md"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/satyrlord/ejay-mix-reader.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "daisyui": "^5.5.19",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "markdownlint-cli2": "^0.22.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vite-plugin-istanbul": "^8.0.0",
    "vitest": "^4.1.4"
  }
}
