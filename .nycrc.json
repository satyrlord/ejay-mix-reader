{
  "all": false,
  "include": [
    "src/main.ts",
    "src/data.ts",
    "src/library.ts",
    "src/player.ts",
    "src/render/icons.ts",
    "src/render/transport.ts",
    "src/render/sidebar.ts",
    "src/render/grid.ts",
    "src/render/home.ts",
    "src/sample-grid-context-menu.ts",
    "src/mix-file-browser.ts",
    "src/mix-player.ts",
    "src/mix-buffer.ts",
    "src/mix-parser.ts"
  ],
  "exclude": [
    "dist/**",
    "coverage/**",
    "node_modules/**"
  ],
  "excludeAfterRemap": false,
  "extension": [
    ".ts",
    ".js"
  ],
  "report-dir": "coverage",
  "reporter": [
    "text",
    "html",
    "lcov"
  ],
  "temp-dir": ".nyc_output",
  "check-coverage": true,
  "per-file": true,
  "statements": 80,
  "branches": 80,
  "functions": 80,
  "lines": 80
}
