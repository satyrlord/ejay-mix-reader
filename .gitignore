# Source data (read-only, large, not tracked in VCS)
archive/

# Proprietary DLLs, compiled tools, and cross-verification scripts
# (Windows-only; binary; potential copyright concerns)
codec/

# Project configuration and agent instructions (workspace-local)
.github/

# Extracted audio output (derived from copyrighted source material)
output/

# Binary file types — never track regardless of location
*.wav
*.exe
*.dll

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
dist/
build/

# VS Code workspace settings
.vscode/

# OS artefacts
.DS_Store
Thumbs.db
