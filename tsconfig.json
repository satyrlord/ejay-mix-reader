  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["*.ts", "scripts/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "vite.config.ts"]
}
