{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  // Node-side runtime: top-level scripts plus scripts/. Browser runtime is
  // covered by tsconfig.browser.json. Test files (Vitest + Playwright) are
  // type-checked by tsconfig.test.json so a typo in a test cannot block a
  // production build.
  "include": ["*.ts", "scripts/**/*.ts"],
  "exclude": [
    "node_modules",
    "scripts/__tests__/**"
  ]
}
