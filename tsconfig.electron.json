  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": false,
    "outDir": "dist-electron",
    "rootDir": ".",
    "skipLibCheck": true,
    "types": ["node", "electron"],
    "sourceMap": true
  },
  "include": ["electron/**/*.ts"]
}
